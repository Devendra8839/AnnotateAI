{
  "name": "@annotate-ai/core",
  "version": "0.1.0",
  "description": "Universal SDK for AnnotateAI",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format iife,esm --global-name AnnotateAI --clean --dts",
